# ============================================================
# REZ Ecosystem — Docker Compose Environment Variables
# ============================================================
# Copy this file to .env (in the repo root) and fill in values.
# These are DEVELOPMENT ONLY — never use these in production.
# ============================================================

# ── MongoDB ──────────────────────────────────────────────
# Single node (for development):
# MONGODB_URI=mongodb://localhost:27017/rez_dev
#
# Replica set (for production-like local dev):
MONGODB_URI=mongodb://localhost:27017,localhost:27018,localhost:27019/rez_dev?replicaSet=rs0
#
# Read preference: primary (default) | secondary | primaryPreferred | secondaryPreferred | nearest
# Use 'secondary' for analytics/reporting queries to offload primary
MONGODB_READ_PREFERENCE=primary
MONGODB_AUTH_SOURCE=admin

# ── Redis ────────────────────────────────────────────────
# Single node (development):
REDIS_URL=redis://localhost:6379

# Sentinel mode (HA with automatic failover):
# Format: redis+sentinel://:password@host:port/service_name?sentinel_master=mymaster
# REDIS_URL=redis+sentinel://:redis_primary_password@localhost:26379,mongodb:26380,mongodb:26381/0?sentinel_master=mymaster

# Redis Sentinel hosts (comma-separated):
SENTINEL_HOSTS=localhost:26379,localhost:26380,localhost:26381
SENTINEL_MASTER=mymaster
REDIS_PASSWORD=redis_primary_password

# ── PostgreSQL (for Rendez, Hotel OTA) ───────────────────
POSTGRES_USER=rez
POSTGRES_PASSWORD=change-me-in-dev
POSTGRES_DB=rez_dev
DATABASE_URL=postgresql://rez:change-me-in-dev@localhost:5432/rez_dev

# ── JWT Secrets (dev only) ───────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_ADMIN_SECRET=change-me-generate-with-openssl-rand-hex-32
JWT_MERCHANT_SECRET=change-me-generate-with-openssl-rand-hex-32

# ── OTP ──────────────────────────────────────────────────
OTP_HMAC_SECRET=change-me-generate-with-openssl-rand-hex-32
OTP_TOTP_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-hex-32
EXPOSE_DEV_OTP=true

# ── Encryption ────────────────────────────────────────────
ENCRYPTION_KEY=change-me-32-bytes-exactly-here!!

# ── OAuth2 ───────────────────────────────────────────────
REZ_OAUTH_CLIENT_SECRET=change-me-generate-with-openssl-rand-base64-64

# ── Internal Service Auth ─────────────────────────────────
INTERNAL_SERVICE_TOKEN=dev-internal-token-change-in-production

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=debug
NODE_ENV=development

# ── Vercel (for deploy workflows) ────────────────────────
# Add these to GitHub Secrets for CI/CD:
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_org_id
# VERCEL_NOW_PROJECT_ID=your_project_id
# VERCEL_STAGING_URL=https://your-staging-url.vercel.app

# ── Render Deploy Hooks ────────────────────────────────────
# Add these to GitHub Secrets for auto-deploy:
# RENDER_AUTH_SERVICE_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxx?key=xxx
# RENDER_MERCHANT_SERVICE_DEPLOY_HOOK=https://api.render.com/deploy/srv-xxx?key=xxx

# ── Slack Notifications ───────────────────────────────────
# Add these to GitHub Secrets for deployment notifications:
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_DEPLOY_CHANNEL=C05XXXXXXXXX
