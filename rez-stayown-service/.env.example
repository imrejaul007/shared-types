# rez-stayown-service
# StayOwn Hotel Service for CorpPerks

# Service
PORT=4015
NODE_ENV=production
SERVICE_NAME=rez-stayown-service

# Database
MONGODB_URI=mongodb://localhost:27017/rez-stayown

# CORS
CORS_ORIGIN=https://admin.rez.money,https://rez-app.vercel.app

# StayOwn Hotel OTA API (ReZ's own hotel platform)
# The StayOwn API is part of Hotel OTA stack
STAYOWN_API_URL=https://hotel-ota-api.onrender.com

# Internal Service Auth
INTERNAL_SERVICE_TOKEN=generate_random_token_here

# REZ Core Services Integration
ORDER_SERVICE_URL=https://rez-order-service.onrender.com
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
