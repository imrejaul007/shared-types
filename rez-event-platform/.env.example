# Service Configuration
SERVICE_NAME=rez-event-platform
PORT=4008
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-events

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# BullMQ
BULLMQ_CONCURRENCY=5
BULLMQ_MAX_RETRIES=3
BULLMQ_RETRY_DELAY=5000

# Event Platform
EVENT_SCHEMA_VERSION=1.0.0
ENABLE_DEAD_LETTER_QUEUE=true
DEAD_LETTER_RETENTION_DAYS=7

# Logging
LOG_LEVEL=info
