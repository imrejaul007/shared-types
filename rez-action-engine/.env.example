# Environment variables for REZ Action Engine
# Copy to .env and configure

# Service Configuration
PORT=4009
NODE_ENV=development

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/rez-action-engine

# Event Platform (REZ Event Platform)
EVENT_PLATFORM_HOST=localhost
EVENT_PLATFORM_PORT=4001
EVENT_PLATFORM_API_KEY=

# NextaBiZ Integration
NEXTABIZ_API_URL=http://localhost:4002
NEXTABIZ_API_KEY=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
