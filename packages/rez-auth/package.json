{
  "name": "@rez/auth",
  "version": "1.0.0",
  "description": "Shared authentication utilities for ReZ ecosystem - JWT verification, token parsing, user ID extraction, and session validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./jwt": {
      "types": "./dist/jwt.d.ts",
      "import": "./dist/jwt.js",
      "require": "./dist/jwt.js"
    },
    "./session": {
      "types": "./dist/session.d.ts",
      "import": "./dist/session.js",
      "require": "./dist/session.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js",
      "require": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint src --max-warnings 0"
  },
  "keywords": [
    "auth",
    "jwt",
    "token",
    "session",
    "rez"
  ],
  "peerDependencies": {
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {}
}
