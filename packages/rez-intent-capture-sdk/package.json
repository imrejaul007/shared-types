{
  "name": "@rez/intent-capture-sdk",
  "version": "1.0.0",
  "description": "Unified Intent Capture SDK for ReZ ecosystem apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "module": "dist/index.mjs",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "clean": "rm -rf dist",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "publish:npm": "npm run build && npm publish --access public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "intent-capture",
    "user-behavior",
    "analytics",
    "sdk",
    "rez"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rez/rez-intent-capture-sdk"
  },
  "license": "MIT"
}
