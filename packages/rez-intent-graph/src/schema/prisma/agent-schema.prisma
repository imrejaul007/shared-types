// ── Agent Database Schema ─────────────────────────────────────────────────────────
// Extension to intent-graph.prisma for agent-specific tables

// This file should be merged with the main schema.prisma file

// Agent event tracking tables (for agents to read from)

model NudgeEvent {
  id            String    @id @default(cuid())
  nudgeId       String
  userId        String
  channel       String    // push, email, sms, in_app
  status        String    // delivered, opened, clicked, converted
  merchantId    String?
  intentKey     String?
  category      String?
  cost          Decimal?  @db.Decimal(10,2)
  metadata      Json?
  sentAt        DateTime  @default(now())
  processed     Boolean   @default(false)

  @@index([userId, sentAt])
  @@index([nudgeId])
  @@index([status, sentAt])
}

model NudgeConversion {
  id            String    @id @default(cuid())
  nudgeId       String
  userId        String
  merchantId    String?
  orderValue    Decimal?  @db.Decimal(10,2)
  convertedAt   DateTime  @default(now())
  metadata      Json?

  @@index([nudgeId])
  @@index([userId, convertedAt])
}

model ScoredIntent {
  id                  String    @id @default(cuid())
  intentId            String    @unique
  userId              String
  intentKey           String
  predictedProb       Decimal   @db.Decimal(3,3)
  confidence          Decimal   @db.Decimal(3,3)
  modelVersion        String
  factors             Json      // {userHistory, timeOfDay, category, price, velocity}
  createdAt           DateTime  @default(now())

  @@index([userId])
  @@index([intentId])
}

model MerchantInventory {
  id              String    @id @default(cuid())
  merchantId      String
  productId       String
  availableCount  Int       @default(0)
  reservedCount   Int       @default(0)
  updatedAt       DateTime  @updatedAt

  @@unique([merchantId, productId])
  @@index([merchantId])
}

model OrderMetric {
  id              String    @id @default(cuid())
  merchantId      String
  orderId         String    @unique
  orderValue      Decimal   @db.Decimal(10,2)
  userId          String
  category        String
  attributedNudge String?   // nudge_id that influenced this order
  createdAt       DateTime  @default(now())

  @@index([merchantId, createdAt])
  @@index([userId])
  @@index([attributedNudge])
}

model UserMetric {
  id                String    @id @default(cuid())
  userId            String    @unique
  avgSessionValue    Decimal   @db.Decimal(10,2)
  conversionRate    Decimal   @db.Decimal(3,3)
  totalOrders       Int       @default(0)
  lastActiveAt      DateTime
  updatedAt         DateTime  @updatedAt

  @@index([userId])
}

model ChannelMetric {
  id              String    @id @default(cuid())
  channel         String    // push, email, sms, in_app
  date            DateTime
  cost            Decimal   @db.Decimal(10,2)
  revenue         Decimal   @db.Decimal(10,2)
  impressions     Int
  clicks          Int
  conversions     Int
  updatedAt       DateTime  @updatedAt

  @@unique([channel, date])
  @@index([date])
}
