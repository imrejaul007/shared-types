{
  "name": "@rez/intent-graph",
  "version": "0.1.0",
  "description": "ReZ Mind - AI-powered commerce intelligence platform with autonomous agents for intent tracking, dormant revival, and personalized nudges",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/server/server.js",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "test:agents": "tsx src/test/agent-test.ts",
    "test:smoke": "tsx src/test/smoke-test.ts",
    "test:server": "tsx src/server/server.ts",
    "test:agent-server": "tsx src/server/agent-server.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "express": "^4.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@types/ws": "^8.18.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/schema/prisma/index.d.ts",
      "default": "./dist/schema/prisma/index.js"
    }
  }
}
