# ===================================================================
# rez-marketing-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4000
SERVICE_NAME=rez-marketing-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-marketing?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>
ADBAZAAR_INTERNAL_KEY=<internal-key>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app
FRONTEND_URL=https://app.rez.money

# === Email [REQUIRED for email campaigns] ===
AWS_ACCESS_KEY_ID=<aws-access-key>
AWS_SECRET_ACCESS_KEY=<aws-secret-key>
AWS_SES_SMTP_USER=<ses-username>
AWS_SES_SMTP_PASS=<ses-password>
AWS_REGION=ap-south-1

# === Internal Auth ===
INTERNAL_SERVICE_KEY=<internal-key>

# === Analytics ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>

# === Marketing ===
MARKETING_SERVICE_URL=https://rez-marketing-service.onrender.com
