# ===================================================================
# rez-karma-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4011
SERVICE_NAME=rez-karma-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez_karma?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_SENTINEL_HOSTS=<host1>:26379,<host2>:26379
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINEL_PASSWORD=<sentinel-password>

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>
JWT_REFRESH_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Service URLs ===
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com

# === Push Notifications ===
FCM_SERVER_KEY=<firebase-cloud-messaging-server-key>

# === Analytics ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>

# === Batch Processing ===
BATCH_CRON_SCHEDULE=0 */6 * * *
