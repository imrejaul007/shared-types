# ===================================================================
# rez-gamification-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=3001
SERVICE_NAME=rez-gamification-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
INTERNAL_HMAC_KEY=<generate-hmac-key>
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Service URLs ===
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
KARMA_SERVICE_URL=https://rez-karma-service.onrender.com

# === Internal Auth ===
INTERNAL_SERVICE_TOKEN=<internal-token>

# === Analytics ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>
