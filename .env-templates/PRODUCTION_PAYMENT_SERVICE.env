# ===================================================================
# rez-payment-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4001
HEALTH_PORT=4101
SERVICE_NAME=rez-payment-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-payment?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Payment Gateway [REQUIRED] ===
RAZORPAY_KEY_ID=<razorpay-key-id>
RAZORPAY_KEY_SECRET=<razorpay-key-secret>

# === Service URLs ===
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com
MERCHANT_SERVICE_URL=https://rez-merchant-service.onrender.com
ORDER_SERVICE_URL=https://rez-order-service.onrender.com
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com

# === Internal Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "<token>", "wallet-service": "<token>", "auth-service": "<token>"}
INTERNAL_WEBHOOK_SECRET=<generate-webhook-secret>

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>

# === Rate Limiting ===
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
