# ===================================================================
# rez-auth-service - PRODUCTION ENVIRONMENT
# ===================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4002
HEALTH_PORT=4102
SERVICE_NAME=rez-auth-service
LOG_LEVEL=info

# === Database [REQUIRED] ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-auth?authSource=admin&retryWrites=true&w=majority

# === Cache [REQUIRED] ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
# For Sentinel: REDIS_SENTINEL_HOSTS=<host1>:26379,<host2>:26379
# For Sentinel: REDIS_SENTINEL_NAME=mymaster
REDIS_PASSWORD=<generate-with-openssl-rand-hex-32>

# === Security [REQUIRED] ===
JWT_SECRET=<generate-64-chars-minimum-with-openssl-rand-base64-64>
JWT_REFRESH_SECRET=<generate-64-chars-minimum>
JWT_ADMIN_SECRET=<generate-64-chars-minimum>
# Bcrypt rounds for password hashing (12 = 2^12 iterations)
BCRYPT_ROUNDS=12

# === CORS [REQUIRED] ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app,https://admin.rez.money

# === OAuth [REQUIRED for OAuth features] ===
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_APPLE_CLIENT_ID=
OAUTH_APPLE_TEAM_ID=
OAUTH_APPLE_KEY_ID=
OAUTH_APPLE_PRIVATE_KEY_PATH=
APP_URL=https://app.rez.money

# === Multi-Factor Auth ===
OTP_TOTP_ENCRYPTION_KEY=<generate-32-char-key>

# === App Check [REQUIRED for production] ===
APP_CHECK_SECRET_KEY=<google-app-check-secret>

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>
OTEL_EXPORTER_OTLP_ENDPOINT=<otlp-endpoint>

# === Internal Service Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "<token>", "payment-service": "<token>", "wallet-service": "<token>", "catalog-service": "<token>", "marketing-service": "<token>"}

# === Redis Sentinel (optional) ===
REDIS_SENTINEL_HOSTS=
REDIS_SENTINEL_NAME=mymaster
REDIS_SENTINEL_PASSWORD=
