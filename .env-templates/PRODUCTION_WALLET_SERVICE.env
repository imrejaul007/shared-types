# ===================================================================
# rez-wallet-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=3010
SERVICE_NAME=rez-wallet-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-wallet?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Service URLs ===
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
MERCHANT_SERVICE_URL=https://rez-merchant-service.onrender.com
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com

# === Internal Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "<token>", "payment-service": "<token>", "auth-service": "<token>"}

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>

# === Rate Limiting ===
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
