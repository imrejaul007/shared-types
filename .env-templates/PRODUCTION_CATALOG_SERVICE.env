# ===================================================================
# rez-catalog-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=3005
SERVICE_NAME=rez-catalog-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-catalog?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
INTERNAL_HMAC_SECRET=<generate-hmac-secret>
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Internal Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "<token>", "auth-service": "<token>"}

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>
