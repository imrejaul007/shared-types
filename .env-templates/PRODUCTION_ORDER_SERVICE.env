# ===================================================================
# rez-order-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4003
SERVICE_NAME=rez-order-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-order?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Service URLs ===
AUTH_SERVICE_URL=https://rez-auth-service.onrender.com
PAYMENT_SERVICE_URL=https://rez-payment-service.onrender.com
WALLET_SERVICE_URL=https://rez-wallet-service.onrender.com

# === Internal Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"auth-service": "<token>", "payment-service": "<token>", "wallet-service": "<token>"}

# === RTMN / Analytics ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
REZ_MIND_URL=https://rez-mind.onrender.com

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>

# === Events ===
EVENT_STREAM_NAME=rez-orders
