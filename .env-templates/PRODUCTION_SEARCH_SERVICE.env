# ===================================================================
# rez-search-service - PRODUCTION ENVIRONMENT
# ===================================================================
# NEVER commit .env files with real credentials!
# ===================================================================

# === Core Service Config ===
NODE_ENV=production
PORT=4006
SERVICE_NAME=rez-search-service
LOG_LEVEL=info

# === Database ===
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/rez-search?authSource=admin&retryWrites=true&w=majority

# === Cache ===
REDIS_URL=redis://:<password>@<redis-host>:<redis-port>
REDIS_TLS=true

# === Security ===
JWT_SECRET=<generate-64-chars-minimum>

# === CORS ===
CORS_ORIGIN=https://app.rez.money,https://rez-app-admin.vercel.app

# === Service URLs ===
CATALOG_SERVICE_URL=https://rez-catalog-service.onrender.com
ORDER_SERVICE_URL=https://rez-order-service.onrender.com

# === Internal Auth ===
INTERNAL_SERVICE_TOKENS_JSON={"order-service": "<token>", "catalog-service": "<token>"}

# === Analytics ===
INTENT_CAPTURE_URL=https://rez-intent-graph.onrender.com
REZ_MIND_URL=https://rez-mind.onrender.com

# === Monitoring ===
SENTRY_DSN=<sentry-dsn>
